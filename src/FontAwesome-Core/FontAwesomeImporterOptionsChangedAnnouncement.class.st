"
I announce that the importer options changed.

I am used when the available styles, categories, or icons are recomputed from the source metadata.
"
Class {
	#name : 'FontAwesomeImporterOptionsChangedAnnouncement',
	#superclass : 'Announcement',
	#category : 'FontAwesome-Core',
	#package : 'FontAwesome-Core'
}
