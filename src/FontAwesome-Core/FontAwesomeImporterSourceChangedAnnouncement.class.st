"
I announce that the importer source file or source-derived state changed.

I am used when the configured icons file changes or when source data is reloaded.
"
Class {
	#name : 'FontAwesomeImporterSourceChangedAnnouncement',
	#superclass : 'Announcement',
	#category : 'FontAwesome-Core',
	#package : 'FontAwesome-Core'
}
